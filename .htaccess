<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteRule (^|/)\.(git|vscode)(/|$) - [F,L]
</IfModule>

<FilesMatch "\.(php|bak|old|orig|save|tmp|log|sql|zip|tar|gz|7z|rar|py|ps1|md|txt)$">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>
